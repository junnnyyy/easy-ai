# Supabase 프로젝트 URL (앱인토스 콘솔 > Supabase > Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon (public) key — 클라이언트에 노출되어도 됨 (RLS로 보호)
VITE_SUPABASE_ANON_KEY=your-anon-key

# 앱인토스 인앱 광고 단위 ID (콘솔에서 발급 후 입력)
# 출시 전에는 테스트 ID 사용 가능:
#   배너 리스트형 : ait-ad-test-banner-id
#   배너 피드형   : ait-ad-test-native-image-id
#   리워드/전면   : 별도 테스트 ID는 앱인토스 콘솔 참고
VITE_AIT_BANNER_AD_GROUP_ID=ait-ad-test-banner-id
VITE_AIT_REWARDED_AD_GROUP_ID=ait-ad-test-rewarded-id

# ⚠️ 아래 키들은 절대 클라이언트 코드에 쓰지 말 것 (Edge Function 환경에만 설정 — Supabase Secrets)
# SUPABASE_SERVICE_ROLE_KEY — Supabase 서비스 롤 키
# OPENAI_API_KEY            — OpenAI API 키
# NAVER_CLIENT_ID           — 네이버 검색 API Client ID (수혜주 찾기·종목분석 뉴스 검색)
# NAVER_CLIENT_SECRET       — 네이버 검색 API Client Secret
# FRED_API_KEY              — 미국 FRED API 키 (종목분석 거시 지표: 기준금리·국채·CPI·PPI)
# ECOS_API_KEY              — 한국은행 ECOS API 키 (종목분석 거시 지표: 기준금리·국고채·CPI)
